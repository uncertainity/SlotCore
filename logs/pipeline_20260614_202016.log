from zipfile import ZipFile
from pathlib import Path
import xml.etree.ElementTree as ET
import re
p=Path('specs/math_models/Parsheet_Vegas_Blitz.xlsx')
NS={'a':'http://schemas.openxmlformats.org/spreadsheetml/2006/main','r':'http://schemas.openxmlformats.org/officeDocument/2006/relationships'}

def colrow(ref):
 m=re.match(r'([A-Z]+)([0-9]+)', ref)
 col=0
 for ch in m.group(1): col=col*26+ord(ch)-64
 return col, int(m.group(2))

def read_shared(z):
 root=ET.fromstring(z.read('xl/sharedStrings.xml'))
 out=[]
 for si in root.findall('a:si',NS):
  texts=[]
  for t in si.findall('.//a:t',NS): texts.append(t.text or '')
  out.append(''.join(texts))
 return out

def cell_value(c, shared):
 t=c.attrib.get('t')
 f=c.find('a:f',NS)
 v=c.find('a:v',NS)
 val=None
 if v is not None:
  val=v.text
  if t=='s': val=shared[int(val)]
  elif t=='b': val=bool(int(val))
  else:
   try:
    fv=float(val)
    val=int(fv) if fv.is_integer() else fv
   except Exception: pass
 if f is not None:
  return f'={f.text}' + (f' -> {val}' if val is not None else '')
 return val
with ZipFile(p) as z:
 shared=read_shared(z)
 wb=ET.fromstring(z.read('xl/workbook.xml'))
 rels=ET.fromstring(z.read('xl/_rels/workbook.xml.rels'))
 relmap={rel.attrib['Id']: rel.attrib['Target'] for rel in rels}
 for s in wb.find('a:sheets',NS):
  name=s.attrib['name']; rid=s.attrib['{http://schemas.openxmlformats.org/officeDocument/2006/relationships}id']
  target='xl/'+relmap[rid]
  root=ET.fromstring(z.read(target))
  print('\\n### SHEET', name)
  rows=[]
  for row in root.findall('.//a:sheetData/a:row',NS):
   entries=[]
   for c in row.findall('a:c',NS):
    val=cell_value(c, shared)
    if val is not None:
     entries.append((c.attrib['r'], val))
   if entries:
    print(' | '.join(f'{ref}={val}' for ref,val in entries))
