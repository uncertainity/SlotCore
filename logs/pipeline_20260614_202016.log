/bin/bash -lc "python3 - <<'PY'
from zipfile import ZipFile
from pathlib import Path
import xml.etree.ElementTree as ET, re, json
p=Path('specs/math_models/Parsheet_Vegas_Blitz.xlsx')
NS={'a':'http://schemas.openxmlformats.org/spreadsheetml/2006/main','r':'http://schemas.openxmlformats.org/officeDocument/2006/relationships'}

def col_to_num(c):
 n=0
 for ch in c: n=n*26+ord(ch)-64
 return n

def ref_to_rc(ref):
 m=re.match(r'([A-Z]+)(\\d+)', ref); return int(m.group(2)), col_to_num(m.group(1))

def read_book(path):
 data={}
 with ZipFile(path) as z:
  shared=[]
  root=ET.fromstring(z.read('xl/sharedStrings.xml'))
  for si in root.findall('a:si',NS): shared.append(''.join(t.text or '' for t in si.findall('.//a:t',NS)))
  wb=ET.fromstring(z.read('xl/workbook.xml'))
  rels=ET.fromstring(z.read('xl/_rels/workbook.xml.rels'))
  relmap={rel.attrib['Id']: rel.attrib['Target'] for rel in rels}
  for s in wb.find('a:sheets',NS):
   name=s.attrib['name']; rid=s.attrib['{http://schemas.openxmlformats.org/officeDocument/2006/relationships}id']
   root=ET.fromstring(z.read('xl/'+relmap[rid]))
   cells={}
   for c in root.findall('.//a:sheetData/a:row/a:c',NS):
    v=c.find('a:v',NS)
    if v is None: continue
    val=v.text
    if c.attrib.get('t')=='s': val=shared[int(val)]
    else:
     try:
      fv=float(val); val=int(fv) if fv.is_integer() else fv
     except: pass
    cells[ref_to_rc(c.attrib['r'])]=val
   data[name]=cells
 return data
book=read_book(p)
rs=book['Reelsets']
def col_values(c, start=4):
 arr=[]
 r=start
 while True:
  v=rs.get((r,c))
  if v is None:
   # allow trailing blanks? stop after 5 empty rows
   if all(rs.get((rr,c)) is None for rr in range(r, r+5)): break
  else: arr.append(v)
  r+=1
 return arr
sets={'B1':range(2,8),'B2':range(10,16),'F1':range(18,24)}
for name, cols in sets.items():
 print(name)
 for i,c in enumerate(cols,1):
  arr=col_values(c)
  print(' R%d len=%d %s'%(i,len(arr), ','.join(map(str,arr))))
